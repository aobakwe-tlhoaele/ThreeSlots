<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <context-param>
        <param-name>AmountOne</param-name>
        <param-value>3000</param-value>
    </context-param>
    <context-param>
        <param-name>AmountTwo</param-name>
        <param-value>1500</param-value>
    </context-param>
    <context-param>
        <param-name>AmountThree</param-name>
        <param-value>700</param-value>
    </context-param>
    <context-param>
        <param-name>AmountFour</param-name>
        <param-value>350</param-value>
    </context-param>
    <context-param>
        <param-name>AmountFive</param-name>
        <param-value>100</param-value>
    </context-param>
    <context-param>
        <param-name>AmountSix</param-name>
        <param-value>50</param-value>
    </context-param>
    <context-param>
        <param-name>GameName</param-name>
        <param-value>3-Reel Slots</param-value>
    </context-param>
    <servlet>
        <servlet-name>StartSessionServlet</servlet-name>
        <servlet-class>za.ac.tut.web.StartSessionServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GenerateSlotServlet</servlet-name>
        <servlet-class>za.ac.tut.web.GenerateSlotServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>OutComeSevlet</servlet-name>
        <servlet-class>za.ac.tut.web.OutComeSevlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EndSessionServlet</servlet-name>
        <servlet-class>za.ac.tut.web.EndSessionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StartSessionServlet</servlet-name>
        <url-pattern>/StartSessionServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GenerateSlotServlet</servlet-name>
        <url-pattern>/GenerateSlotServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>OutComeSevlet</servlet-name>
        <url-pattern>/OutComeSevlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EndSessionServlet</servlet-name>
        <url-pattern>/EndSessionServlet.do</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    <error-page>
        <error-code>404</error-code>
        <location>/File_not_found.jsp</location>
    </error-page>
    <error-page>
        <exception-type>za.ac.tut.web.bl.InvalidFunds</exception-type>
        <location>/No_Funds.jsp</location>
    </error-page>
</web-app>
